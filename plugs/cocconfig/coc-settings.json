{
  "languageserver":{
    "coc-clangd":{
      "command":"clangd",
      "filetypes":[
        "c",
        "cpp"
      ],
      "rootPatterns":[
        "compile_commands.json",
        ".git"
      ],
      "args":[
        "--compile-commands-dir=build",
        "--compile_args_from=filesystem",
        "--all-scopes-completion",
        "--background-index",
        "--clang-tidy",
        "--cross-file-rename",
        "--completion-parse=always",
        "--completion-style=detailed",
        "--function-arg-placeholders",
        "--header-insertion-decorators",
        "--query-driver=/usr/bin/**/clang-*,/home/adem/GCC-10/bin/g++*",
        "--header-insertion=never",
        "--limit-results=0",
        "-j=6",
        "--pch-storage=memory"
      ]
    },
   "go": {
	   "command": "gopls",
	   "rootPatterns": ["go.work", "go.mod", ".vim/", ".git/", ".hg/"],
	   "filetypes": ["go"],
	   "initializationOptions": {
		   "usePlaceholders": true
	   }
   },
   "csharp": {
	   "command": "omnisharp",
	   "args": ["-lsp"],
	   "rootPatterns": ["*.slnx","*.sln", "*.csproj", ".git/"],
	   "filetypes": ["cs"],
	   "trace.server": "off"
   },
   //"godot": {
   //    "host": "127.0.0.1",
   //    "port": 6005,
   //    "filetypes": ["gd", "gdscript", "gdscript3"],
   //    "rootPatterns": ["*.godot", ".git"],
   //    "trace.server": "off"
   //},
   "gdshader": {
	   "command": "gdshader-language-server",
	   "filetypes": ["gsl"]
   },
   "glslls": {
      "command": "glslls",
      "args": ["--stdin","--target-env", "opengl"],
      "filetypes": ["glsl", "vert", "frag", "geom", "comp"],
      "rootPatterns": [".git"],
      "settings": {
        "glslls": {
          "capabilities": {
            "hoverProvider": true,
            "completionProvider": true,
            "definitionProvider": true
          }
        }
      }
    }
  },
  "suggest.noselect": true,
   "suggest.disableKeymap": true,
   "coc.preferences.completion.autoTrigger" : true,
   "inlayHint.enable":true,
  "snippets.userSnippetsDirectory": "~/.vim/plugged/vim-snippets/snippets",
  "snippets.ultisnips.pythonPrompt": false
}

